$scope module fifo_tb_top $end
$var reg       1 !    wrclk $end
$var reg       1 "    rdclk $end

$scope module dut_if $end
$var wire      1 #    wrclk  $end
$var wire      1 $    rdclk  $end
$var reg       1 %    wrst_n $end
$var reg       1 &    rrst_n $end
$var reg       1 '    wr_en $end
$var reg       1 (    rd_en $end
$var reg      64 )    data_in [63:0] $end
$var reg      64 *    data_out [63:0] $end
$var reg       1 +    fifo_full $end
$var reg       1 ,    fifo_empty $end
$var reg       4 -    b_rptr_mon [3:0] $end
$upscope $end


$scope module dut $end
$var parameter 32 .    FIFO_DEPTH $end
$var parameter 32 /    FIFO_WIDTH $end
$var wire      1 0    wrclk  $end
$var wire      1 1    wrst_n  $end
$var wire      1 2    rdclk  $end
$var wire      1 3    rrst_n  $end
$var wire      1 4    wr_en  $end
$var wire      1 5    rd_en  $end
$var wire     64 6    data_in [63:0] $end
$var reg      64 7    data_out [63:0] $end
$var reg       1 8    fifo_full $end
$var reg       1 9    fifo_empty $end
$var parameter 32 :    PTR_WIDTH $end
$var reg       4 ;    g_wptr_sync [3:0] $end
$var reg       4 <    g_rptr_sync [3:0] $end
$var reg       4 =    g_wptr [3:0] $end
$var reg       4 >    g_rptr [3:0] $end
$var reg       4 ?    b_wptr [3:0] $end
$var reg       4 @    b_rptr [3:0] $end
$var wire      3 A    waddr [2:0] $end
$var wire      3 B    raddr [2:0] $end

$scope module sync_wptr $end
$var parameter 32 C    WIDTH $end
$var wire      1 2    clk  $end
$var wire      1 3    rst_n  $end
$var wire      4 D    d_in [3:0] $end
$var reg       4 E    d_out [3:0] $end
$var reg       4 F    q1 [3:0] $end
$upscope $end


$scope module sync_rptr $end
$var parameter 32 G    WIDTH $end
$var wire      1 0    clk  $end
$var wire      1 1    rst_n  $end
$var wire      4 H    d_in [3:0] $end
$var reg       4 I    d_out [3:0] $end
$var reg       4 J    q1 [3:0] $end
$upscope $end


$scope module wrptr_h $end
$var parameter 32 K    PTR_WIDTH $end
$var wire      1 0    wrclk  $end
$var wire      1 1    wrst_n  $end
$var wire      1 4    wr_en  $end
$var wire      4 L    g_rptr_sync [3:0] $end
$var reg       4 M    b_wptr [3:0] $end
$var reg       4 N    g_wptr [3:0] $end
$var reg       1 O    fifo_full $end
$var reg       4 P    b_wptr_next [3:0] $end
$var reg       4 Q    g_wptr_next [3:0] $end
$var reg       1 R    wrap_around $end
$var wire      1 S    wfull  $end
$upscope $end


$scope module rdptr_h $end
$var parameter 32 T    PTR_WIDTH $end
$var wire      1 2    rdclk  $end
$var wire      1 3    rrst_n  $end
$var wire      1 5    rd_en  $end
$var wire      4 U    g_wptr_sync [3:0] $end
$var reg       4 V    b_rptr [3:0] $end
$var reg       4 W    g_rptr [3:0] $end
$var reg       1 X    fifo_empty $end
$var reg       4 Y    b_rptr_next [3:0] $end
$var reg       4 Z    g_rptr_next [3:0] $end
$var wire      1 [    rempty  $end
$upscope $end


$scope module fifo $end
$var parameter 32 \    FIFO_DEPTH $end
$var parameter 32 ]    FIFO_WIDTH $end
$var parameter 32 ^    PTR_WIDTH $end
$var wire      1 0    wrclk  $end
$var wire      1 4    wr_en  $end
$var wire      1 2    rdclk  $end
$var wire      1 5    rd_en  $end
$var wire      4 _    b_wptr [3:0] $end
$var wire      4 `    b_rptr [3:0] $end
$var wire     64 6    data_in [63:0] $end
$var wire      1 a    fifo_full  $end
$var wire      1 b    fifo_empty  $end
$var reg      64 c    data_out [63:0] $end
$var reg      64 d    fifo[0] [63:0] $end
$var reg      64 e    fifo[1] [63:0] $end
$var reg      64 f    fifo[2] [63:0] $end
$var reg      64 g    fifo[3] [63:0] $end
$var reg      64 h    fifo[4] [63:0] $end
$var reg      64 i    fifo[5] [63:0] $end
$var reg      64 j    fifo[6] [63:0] $end
$var reg      64 k    fifo[7] [63:0] $end
$upscope $end

$upscope $end

$upscope $end

$enddefinitions $end
